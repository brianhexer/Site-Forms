# Email Service Configuration
EMAIL_SERVICE=emailjs          # Options: emailjs, sendgrid, firebase, webhook
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key

# SendGrid Configuration (if using SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key

# Google Firebase (if using Firebase)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# Webhook Configuration (if using custom backend)
WEBHOOK_URL=https://your-backend.com/api/submit-form
WEBHOOK_SECRET=your_webhook_secret

# Form Configuration
FORM_RATE_LIMIT=5              # Max submissions per hour per IP
FORM_SPAM_CHECK=true           # Enable spam protection
ALLOWED_ORIGINS=localhost:3000,example.com   # CORS allowed origins

# Notifications
ADMIN_EMAIL=admin@example.com  # Email to receive form notifications
NOTIFICATION_EMAIL=true        # Send notification on form submit
